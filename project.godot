;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Geoslayer"
config/version="0.2.0"
run/main_scene="uid://d1hbgw27crue0"
config/use_custom_user_dir=true
config/custom_user_dir_name="Geoslayer"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://bxv58y5fxhxyu"

[autoload]

PlayerManager="*uid://cbmflsin26xyg"
WorldManager="*uid://bsml1uo2h07sk"
GameManager="*uid://d0c3pd5wo3gu2"
UserManager="*uid://da7wyp7qrn6f8"
ConfigManager="*uid://cu3xk10tjf0g6"
SignalBus="*uid://c3patbig6i7b3"

[debug]

gdscript/warnings/integer_division=0
gdscript/warnings/narrowing_conversion=0

[display]

window/size/mode=4
window/size/resizable=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[file_customization]

folder_colors={
"res://assets/": "purple",
"res://scenes/": "green",
"res://scripts/": "blue"
}

